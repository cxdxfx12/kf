# ============ 服务端口 ============
SERVER_PORT=3002
NODE_ENV=development

# ============ 数据库配置 ============
# 支持 mysql / postgres / sqlite
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=express_cs
DB_USER=root
DB_PASSWORD=123456

# SQLite 备选（无需安装数据库）：
# DB_DIALECT=sqlite
# DB_STORAGE=./data/database.sqlite

# ============ JWT ============
JWT_SECRET=express-cs-secret-key-change-me
JWT_EXPIRES_IN=7d

# ============ 快递鸟 API (http://www.kdniao.com/) ============
KDNIAO_ENABLED=false
KDNIAO_EBUSINESS_ID=your_kdniao_ebusiness_id
KDNIAO_API_KEY=your_kdniao_api_key
KDNIAO_API_URL=https://api.kdniao.com/Ebusiness/EbusinessOrderHandle.aspx

# ============ 菜鸟 API ============
CAINIAO_ENABLED=false
CAINIAO_APP_KEY=your_cainiao_app_key
CAINIAO_APP_SECRET=your_cainiao_app_secret
CAINIAO_API_URL=https://open.taobao.com/api.htm

# ============ 容联云通讯 (呼叫中心) ============
CCP_ENABLED=false
CCP_ACCOUNT_SID=your_ccp_account_sid
CCP_AUTH_TOKEN=your_ccp_auth_token
CCP_APP_ID=your_ccp_app_id
CCP_REST_URL=https://app.cloopen.com:8883

# ============ 华为云联络中心 ============
HUAWEI_CC_ENABLED=false
HUAWEI_APP_KEY=your_huawei_app_key
HUAWEI_APP_SECRET=your_huawei_app_secret
HUAWEI_API_URL=https://ccportal.cn-north-4.huaweicloud.com

# ============ 通义千问 (阿里云 DashScope) ============
QWEN_ENABLED=false
QWEN_API_KEY=your_dashscope_api_key
QWEN_MODEL=qwen-turbo
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation

# ============ 智谱 AI (GLM) ============
ZHIPU_ENABLED=false
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_MODEL=glm-4
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
